# Set default behavior to automatically normalize line endings
* text=auto

# Explicitly handle certain file types as LF (recommended for JS/TS/JSON/MD/etc)
*.js    text eol=lf
*.ts    text eol=lf
*.md    text eol=lf
*.json  text eol=lf
*.prisma text eol=lf
*.mjs   text eol=lf
*.config.* text eol=lf