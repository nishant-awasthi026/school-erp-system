// Add these models to the main schema.prisma file

model Expense {
  id          String   @id @default(uuid())
  title       String
  amount      Float
  category    String   // e.g., "SALARY", "UTILITIES", "MAINTENANCE"
  description String?
  date        DateTime
  
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id])
  
  createdAt   DateTime @default(now())
}

model Payment {
  id          String   @id @default(uuid())
  amount      Float
  paymentDate DateTime
  method      String   // e.g., "CASH", "ONLINE", "CHEQUE"
  
  feeRecordId String
  feeRecord   FeeRecord @relation(fields: [feeRecordId], references: [id])
  
  createdAt   DateTime @default(now())
}

model Ledger {
  id          String   @id @default(uuid())
  entryType   String   // "INCOME", "EXPENSE"
  amount      Float
  description String
  date        DateTime
  
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id])
  
  createdAt   DateTime @default(now())
}
